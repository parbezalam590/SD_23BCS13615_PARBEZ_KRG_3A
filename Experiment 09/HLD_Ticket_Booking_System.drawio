          <mxGeometry height="500" width="600" x="200" y="250" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-2" parent="qY9Yzxmkbyx34cncm8wa-88" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" value="" vertex="1">
          <mxGeometry height="500" width="600" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-3" parent="qY9Yzxmkbyx34cncm8wa-88" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=13;fontStyle=1;" value="&lt;b&gt;1. Functional Requirements&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="410" x="61.42857142857143" y="10" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-4" parent="qY9Yzxmkbyx34cncm8wa-88" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;" value="&lt;ol&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;User discovers events via filters: &lt;b&gt;Title, City, Date&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;User views event details:&amp;nbsp;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Seats (available/occupied),&amp;nbsp;&lt;/b&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Description, Cast, Duration, Language, Ratings&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;User selects a seat and completes a &lt;b&gt;Booking Transaction&lt;/b&gt;&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="110" width="471.42857142857144" x="14.285714285714286" y="35" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-5" parent="qY9Yzxmkbyx34cncm8wa-88" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=13;fontStyle=1;" value="&lt;b&gt;2. Non-Functional Requirements&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="542.8571428571429" x="35.714285714285715" y="150" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-6" parent="qY9Yzxmkbyx34cncm8wa-88" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;" value="&lt;ol&gt;&lt;li&gt;&lt;b&gt;100 Million DAU&lt;/b&gt; — massive horizontal scale&lt;/li&gt;&lt;li&gt;&lt;b&gt;High Availability (AP)&lt;/b&gt; for Search/Browse — stale data &gt; downtime&lt;/li&gt;&lt;li&gt;&lt;b&gt;High Consistency (CP)&lt;/b&gt; for Booking — no double-booking ever&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="100" width="557.1428571428571" x="14.285714285714286" y="175" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-7" parent="qY9Yzxmkbyx34cncm8wa-88" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=13;fontStyle=1;" value="&lt;b&gt;3. Core Entities&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="542.8571428571429" x="50" y="285" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-8" parent="qY9Yzxmkbyx34cncm8wa-88" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;" value="&lt;ol&gt;&lt;li&gt;&lt;b&gt;User&lt;/b&gt; — id, name, email, phone&lt;/li&gt;&lt;li&gt;&lt;b&gt;Event&lt;/b&gt; — id, title, description, cast, duration, language, rating&lt;/li&gt;&lt;li&gt;&lt;b&gt;Venue&lt;/b&gt; — id, name, city, address&lt;/li&gt;&lt;li&gt;&lt;b&gt;Show&lt;/b&gt; — id, event_id, venue_id, start_time, end_time&lt;/li&gt;&lt;li&gt;&lt;b&gt;Seat&lt;/b&gt; — id, venue_id, row_label, seat_number, type, &lt;b&gt;status&lt;/b&gt; (available/locked/booked)&lt;/li&gt;&lt;li&gt;&lt;b&gt;Booking&lt;/b&gt; — id, user_id, show_id, total_amount, status, timestamp&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="150" width="564.2857142857143" x="14.285714285714286" y="310" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-89" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="270" width="420" x="215" y="767.5" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-9" parent="qY9Yzxmkbyx34cncm8wa-89" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="" vertex="1">
          <mxGeometry height="270" width="420" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-10" parent="qY9Yzxmkbyx34cncm8wa-89" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=13;fontStyle=1;" value="&lt;b&gt;4. API Design&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="380" x="10" y="10" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-11" parent="qY9Yzxmkbyx34cncm8wa-89" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontFamily=Courier New;" value="&lt;b&gt;GET&lt;/b&gt;  /v1/events?title=&amp;city=&amp;date=&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ Returns list of matching events&lt;br&gt;&lt;br&gt;&lt;b&gt;GET&lt;/b&gt;  /v1/events/{event_id}&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ Returns metadata + description for an event&lt;br&gt;&lt;br&gt;&lt;b&gt;GET&lt;/b&gt;  /v1/shows/{show_id}/seats&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ Returns seat map + availability for a show&lt;br&gt;&lt;br&gt;&lt;b&gt;POST&lt;/b&gt; /v1/bookings&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;BODY: { event_id, show_id, seat_id }&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ Locks seat + initiates booking transaction" vertex="1">
          <mxGeometry height="225" width="400" x="10" y="35" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-91" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="300" width="420" x="215" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-12" parent="qY9Yzxmkbyx34cncm8wa-91" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="" vertex="1">
          <mxGeometry height="300" width="420" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-90" connectable="0" parent="qY9Yzxmkbyx34cncm8wa-91" style="group" value="" vertex="1">
          <mxGeometry height="280" width="400" x="10" y="10" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-13" parent="qY9Yzxmkbyx34cncm8wa-90" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=13;fontStyle=1;" value="&lt;b&gt;5. Database Schema Design (PostgreSQL)&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="400" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-14" parent="qY9Yzxmkbyx34cncm8wa-90" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontFamily=Courier New;" value="&lt;b&gt;users:&lt;/b&gt;      id (PK), name, email (UNIQUE), phone&lt;br&gt;&lt;b&gt;events:&lt;/b&gt;     id (PK), title, description, cast,&lt;br&gt;            duration, language, rating&lt;br&gt;&lt;b&gt;venues:&lt;/b&gt;     id (PK), name, city, address&lt;br&gt;&lt;b&gt;shows:&lt;/b&gt;      id (PK), event_id (FK), venue_id (FK),&lt;br&gt;            start_time, end_time&lt;br&gt;&lt;b&gt;seats:&lt;/b&gt;      id (PK), venue_id (FK), row_label,&lt;br&gt;            seat_number, type,&lt;br&gt;            &lt;b&gt;status ENUM(available, locked, booked)&lt;/b&gt;&lt;br&gt;&lt;b&gt;bookings:&lt;/b&gt;   id (PK), user_id (FK), show_id (FK),&lt;br&gt;            total_amount, status, timestamp&lt;br&gt;&lt;br&gt;&lt;i&gt;Indexes: shows(event_id), shows(venue_id),&lt;br&gt;seats(venue_id, status), bookings(user_id)&lt;/i&gt;" vertex="1">
          <mxGeometry height="255" width="400" y="25" as="geometry" />
        </mxCell>
        <mxCell id="qY9Yzxmkbyx34cncm8wa-93" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;span style=&quot;color: rgb(35, 47, 62); font-family: Helvetica; font-size: 11px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 700; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(236, 236, 236); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;Users&lt;/span&gt;&lt;br style=&quot;forced-color-adjust: none; color: rgb(35, 47, 62); font-family: Helvetica; font-size: 11px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 700; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(236, 236, 236); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span style=&quot;color: rgb(35, 47, 62); font-family: Helvetica; font-size: 11px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 700; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(236, 236, 236); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;(Web / Mobile)&lt;/span&gt;" vertex="1">
